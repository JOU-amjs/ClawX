# ClawX Development Environment
# Copy to .env.development.local for local overrides (git-ignored)

# OpenClaw Gateway
OPENCLAW_GATEWAY_PORT=18789

# Vite Dev Server
VITE_DEV_SERVER_PORT=5173

# Data directories (relative to project root)
CLAWX_USER_DATA_DIR=userdata
CLAWX_OPENCLAW_DIR=openclaw-data
CLAWX_CONFIG_DIR=userdata/.clawx
