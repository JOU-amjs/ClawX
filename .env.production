# ClawX Production Environment
# Copy to .env.production.local for local overrides (git-ignored)

# OpenClaw Gateway
# OPENCLAW_GATEWAY_PORT=18789

# Data directories (relative to install directory's parent)
CLAWX_USER_DATA_DIR=../data
CLAWX_OPENCLAW_DIR=../data/.openclaw
CLAWX_CONFIG_DIR=../data/.clawx
CLAWX_PORTABLE=1